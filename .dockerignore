# =============================================================================
# .dockerignore — MIA System
#
# IMPORTANTE: Este archivo DEBE llamarse ".dockerignore" (con punto inicial).
# El archivo anterior "dockerignore" era ignorado por Docker, causando que
# node_modules (~300 MB) se enviara al contexto de build innecesariamente.
# =============================================================================

# --- Dependencias (regeneradas por npm ci en el Dockerfile) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# --- Archivos de entorno (nunca en la imagen) ---
.env
.env.*
!.env.example

# --- Logs ---
*.log
logs/

# --- IDE y editores ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Sistema operativo ---
.DS_Store
Thumbs.db
desktop.ini

# --- Control de versiones ---
.git/
.gitignore
.gitattributes

# --- CI/CD (no necesario en la imagen) ---
.github/
.dockerignore
Dockerfile*
docker-compose*.yml
*.sh
*.ps1

# --- Documentación y archivos de desarrollo ---
docs/
README.md
*.md
IMPLEMENTATION-COMPLETE.txt

# --- Archivos de test ---
src/test/

# NOTA: dist/ NO está en esta lista porque Dockerfile.ci lo necesita.
# Para builds locales con el Dockerfile multi-stage, dist/ se regenera
# en la etapa builder y el contenido previo no afecta el resultado.
